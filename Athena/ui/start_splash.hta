<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<title>Athena</title>
<HTA:APPLICATION
  ID="AthenaSplash"
  APPLICATIONNAME="Athena - Latitude MedTech"
  BORDER="none"
  BORDERSTYLE="none"
  CAPTION="no"
  ICON="C:\Users\huann\LatitudeMedTech\Athena\athena.ico"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SCROLL="no"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
/>
<style>
  * { margin:0; padding:0; box-sizing:border-box; -ms-user-select:none; user-select:none; }

  @-ms-keyframes shimmer {
    0%   { background-position:-300% center; }
    100% { background-position: 300% center; }
  }
  @keyframes shimmer {
    0%   { background-position:-300% center; }
    100% { background-position: 300% center; }
  }
  @-ms-keyframes blink {
    0%,80%,100% { opacity:0.15; }
    40%         { opacity:0.9;  }
  }
  @keyframes blink {
    0%,80%,100% { opacity:0.15; }
    40%         { opacity:0.9;  }
  }

  html { width:100%; height:100%; }
  body {
    width:100%; height:100%;
    font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif;
    overflow:hidden;
    background:#02111f;
    display:-ms-flexbox; display:flex;
    -ms-flex-align:center; align-items:center;
    -ms-flex-pack:center; justify-content:center;
  }

  #card {
    width:100%; height:100%;
    position:relative;
    border-radius:16px;
    overflow:hidden;
    background:#0d2a44;
  }

  /* Sized by Window_OnLoad to cover the card. HTAs render in legacy IE
     mode, which ignores background-size:cover, so we scale a real <img>. */
  #bgImg {
    position:absolute;
    display:none;
    z-index:0;
  }

  #overlay {
    position:absolute;
    top:0; right:0; bottom:0; left:0;
    z-index:1;
    background: -ms-linear-gradient(top,
      rgba(8,28,50,0.00)   0%,
      rgba(8,28,50,0.00)  18%,
      rgba(8,28,50,0.60)  44%,
      rgba(8,28,50,0.88)  58%,
      rgba(8,28,50,0.97)  70%,
      rgba(8,28,50,1.00)  80%,
      rgba(8,28,50,1.00) 100%
    );
    background: linear-gradient(180deg,
      rgba(8,28,50,0.00)   0%,
      rgba(8,28,50,0.00)  18%,
      rgba(8,28,50,0.60)  44%,
      rgba(8,28,50,0.88)  58%,
      rgba(8,28,50,0.97)  70%,
      rgba(8,28,50,1.00)  80%,
      rgba(8,28,50,1.00) 100%
    );
  }

  #content {
    position:absolute;
    bottom:0; left:0; right:0;
    padding:0 60px 48px;
    z-index:2;
  }

  .eyebrow {
    font-size:11px;
    letter-spacing:0.32em;
    color:#C4922A;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:9px;
    text-shadow:0 1px 8px rgba(0,0,0,0.7);
  }
  .name {
    font-size:76px;
    font-weight:200;
    letter-spacing:0.04em;
    color:#EDE6D8;
    line-height:1;
    margin-bottom:9px;
    text-shadow:0 2px 24px rgba(0,0,0,0.85), 0 0 48px rgba(0,0,0,0.4);
  }
  .tagline {
    font-size:13px;
    letter-spacing:0.20em;
    color:rgba(220,210,195,0.65);
    text-transform:uppercase;
    margin-bottom:30px;
    text-shadow:0 1px 8px rgba(0,0,0,0.6);
  }
  .bar-wrap {
    width:100%; height:3px;
    background:rgba(255,255,255,0.08);
    overflow:hidden;
    margin-bottom:15px;
  }
  .bar-fill {
    height:100%; width:0%;
    background: linear-gradient(90deg,
      rgba(196,146,42,0.4),
      rgba(232,184,75,1.0),
      rgba(196,146,42,0.4)
    );
    background-size:300% auto;
    -ms-animation: shimmer 2.4s linear infinite;
    animation:     shimmer 2.4s linear infinite;
    -ms-transition: width 0.5s ease;
    transition:    width 0.5s ease;
  }
  .status-text {
    font-size:13px;
    color:rgba(220,210,195,0.55);
    letter-spacing:0.04em;
  }
  #dot1, #dot2, #dot3 {
    font-size:16px;
    color:rgba(196,146,42,0.5);
    -ms-animation: blink 1.4s ease-in-out infinite both;
    animation:     blink 1.4s ease-in-out infinite both;
  }
  #dot2 { -ms-animation-delay:0.22s; animation-delay:0.22s; }
  #dot3 { -ms-animation-delay:0.44s; animation-delay:0.44s; }
</style>
</head>
<body>

  <div id="card">
  <img id="bgImg" src="file:///C:/Users/huann/LatitudeMedTech/Athena/ui/splash_bg.jpg" alt=""/>
  <div id="overlay"></div>

  <div id="content">
    <div class="eyebrow">Latitude MedTech</div>
    <div class="name">Athena</div>
    <div class="tagline">Advancing Human Intelligence</div>
    <div class="bar-wrap"><div class="bar-fill" id="bar"></div></div>
    <span class="status-text" id="status">Starting up</span><span id="dots">&#160;<span id="dot1">&#183;</span><span id="dot2">&#183;</span><span id="dot3">&#183;</span></span>
  </div>
  </div><!-- #card -->

<script language="VBScript">
Dim bar, statusEl, dotsEl, stepVal, timer_id, poll_id, waited
Dim BACKEND, FRONTEND, MAX_WAIT
Dim dragging, dragLastX, dragLastY
BACKEND  = "http://127.0.0.1:8000/"
FRONTEND = "http://localhost:3000"
MAX_WAIT = 60
waited   = 0

Sub Window_OnLoad
  Dim aw, ah, al, at, pw, ph
  ' availWidth/Height = desktop work area (full screen minus the taskbar)
  aw = Screen.availWidth : ah = Screen.availHeight
  al = Screen.availLeft  : at = Screen.availTop
  ' Centered panel at 70% of the work area
  pw = Int(aw * 0.7) : ph = Int(ah * 0.7)
  window.resizeTo pw, ph
  window.moveTo al + (aw - pw) \ 2, at + (ah - ph) \ 2

  ' Cover-fill the card with the background image (source 1400x350).
  ' Scale so it covers both dimensions, then center; bias slightly left so
  ' the cliffs + palms stay visible and the waves fall on the right.
  ' HTAs render in legacy IE mode, which ignores background-size:cover, so
  ' we scale a real <img> here instead.
  Dim img, sW, sH, scaleW, scaleH, scale, newW, newH
  sW = 1400.0 : sH = 350.0
  scaleW = pw / sW : scaleH = ph / sH
  If scaleW > scaleH Then scale = scaleW Else scale = scaleH
  newW = Int(sW * scale) : newH = Int(sH * scale)
  Set img = document.getElementById("bgImg")
  img.style.width   = newW & "px"
  img.style.height  = newH & "px"
  img.style.left    = Int((pw - newW) / 2 - newW * 0.04) & "px"
  img.style.top     = Int((ph - newH) / 2) & "px"
  img.style.display = "block"

  Set bar      = document.getElementById("bar")
  Set statusEl = document.getElementById("status")
  Set dotsEl   = document.getElementById("dots")
  stepVal = 0

  timer_id = window.setInterval("Tick",       400)
  poll_id  = window.setInterval("PollBackend", 800)

  ' Borderless window has no title bar, so a click-drag grabs the page
  ' content instead of moving the window. Dragging the <img> makes IE pop
  ' the "allow files from this website to be copied to your computer?"
  ' security dialog. Cancel drag + text-selection at the document level.
  ' NB: inline on* attributes are parsed as VBScript here, so a JScript
  ' "return false" throws a script error - wire the handlers in VBScript.
  Set document.ondragstart   = GetRef("CancelEvent")
  Set document.onselectstart = GetRef("CancelEvent")

  ' Click-drag anywhere to move the borderless window.
  dragging = False
  Set document.onmousedown = GetRef("Drag_Begin")
  Set document.onmousemove = GetRef("Drag_Move")
  Set document.onmouseup   = GetRef("Drag_End")
End Sub

Sub CancelEvent
  window.event.returnValue = False
End Sub

' --- Drag-to-move for the borderless window --------------------------------
Sub Drag_Begin
  ' left button only
  If window.event.button = 1 Then
    dragging  = True
    dragLastX = window.event.screenX
    dragLastY = window.event.screenY
    document.body.setCapture           ' keep events during fast drags
  End If
End Sub

Sub Drag_Move
  If dragging Then
    ' Move the window by the same delta the cursor moved. Using moveBy with
    ' deltas avoids window.screenLeft/Top, which can be unreliable in an HTA.
    window.moveBy window.event.screenX - dragLastX, window.event.screenY - dragLastY
    dragLastX = window.event.screenX
    dragLastY = window.event.screenY
  End If
End Sub

Sub Drag_End
  If dragging Then
    dragging = False
    document.releaseCapture
  End If
End Sub

Sub SetStatus(msg, showDots)
  statusEl.innerText = msg
  If showDots Then
    dotsEl.style.display = "inline"
  Else
    dotsEl.style.display = "none"
  End If
End Sub

Sub Tick
  If stepVal < 85 Then
    stepVal = stepVal + 2
    bar.style.width = stepVal & "%"
  End If
End Sub

Sub PollBackend
  waited = waited + 1
  If waited > MAX_WAIT Then
    SetStatus "Connection timed out - please try again", False
    window.clearInterval poll_id
    window.clearInterval timer_id
    window.setTimeout "window.close()", 3000
    Exit Sub
  End If
  Dim xhr
  Set xhr = CreateObject("MSXML2.ServerXMLHTTP")
  On Error Resume Next
  xhr.open "GET", BACKEND, False
  xhr.setTimeouts 500, 500, 500, 500
  xhr.send
  If Err.Number = 0 And xhr.status = 200 Then
    SetStatus "Backend ready - launching interface", True
    bar.style.width = "90%"
    window.clearInterval poll_id
    poll_id = window.setInterval("PollFrontend", 800)
  Else
    SetStatus "Warming up the backend", True
  End If
  On Error Resume Next
  Err.Clear
End Sub

Sub PollFrontend
  Dim xhr
  Set xhr = CreateObject("MSXML2.ServerXMLHTTP")
  On Error Resume Next
  xhr.open "GET", FRONTEND, False
  xhr.setTimeouts 500, 500, 500, 500
  xhr.send
  If Err.Number = 0 And xhr.status = 200 Then
    bar.style.width = "95%"
    SetStatus "Opening in Chrome", True
    window.clearInterval poll_id
    poll_id = window.setInterval("PollChromeReady", 500)
  Else
    SetStatus "Loading the interface", True
  End If
  On Error Resume Next
  Err.Clear
End Sub

Sub PollChromeReady
  Dim fso
  Set fso = CreateObject("Scripting.FileSystemObject")
  If fso.FileExists("C:\Users\huann\LatitudeMedTech\Athena\ui\.athena_ready") Then
    bar.style.width = "100%"
    SetStatus "Welcome back. Athena is ready.", False
    window.clearInterval poll_id
    window.clearInterval timer_id
    window.setTimeout "window.close()", 900
  End If
End Sub
</script>
</body>
</html>
