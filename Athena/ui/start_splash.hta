<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<title>Athena</title>
<HTA:APPLICATION
  ID="AthenaSplash"
  APPLICATIONNAME="Athena - Latitude MedTech"
  BORDER="none"
  BORDERSTYLE="none"
  CAPTION="no"
  ICON="C:\Users\huann\LatitudeMedTech\Athena\athena.ico"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SCROLL="no"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="normal"
/>
<style>
  * { margin:0; padding:0; box-sizing:border-box; -ms-user-select:none; user-select:none; }

  @-ms-keyframes shimmer {
    0%   { background-position:-300% center; }
    100% { background-position: 300% center; }
  }
  @keyframes shimmer {
    0%   { background-position:-300% center; }
    100% { background-position: 300% center; }
  }
  html { width:100%; height:100%; }
  body {
    width:100%; height:100%;
    font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif;
    overflow:hidden;
    background:#0d2a44;
    position:relative;
  }

  /* Sized in Window_OnLoad to cover the panel. Using a real <img> instead
     of CSS background-size:cover because HTAs run in legacy IE mode which
     ignores background-size. IE=edge meta is intentionally omitted — it
     restores the title bar and blocks window.close() from VBScript. */
  #bgImg {
    position:absolute;
    display:none;
    z-index:0;
  }

  #overlay {
    position:absolute;
    top:0; right:0; bottom:0; left:0;
    z-index:1;
    background: -ms-linear-gradient(top,
      rgba(8,28,50,0.00)   0%,
      rgba(8,28,50,0.00)  18%,
      rgba(8,28,50,0.60)  44%,
      rgba(8,28,50,0.88)  58%,
      rgba(8,28,50,0.97)  70%,
      rgba(8,28,50,1.00)  80%,
      rgba(8,28,50,1.00) 100%
    );
    background: linear-gradient(180deg,
      rgba(8,28,50,0.00)   0%,
      rgba(8,28,50,0.00)  18%,
      rgba(8,28,50,0.60)  44%,
      rgba(8,28,50,0.88)  58%,
      rgba(8,28,50,0.97)  70%,
      rgba(8,28,50,1.00)  80%,
      rgba(8,28,50,1.00) 100%
    );
  }

  #content {
    position:absolute;
    bottom:0; left:0; right:0;
    padding:0 72px 60px;
    z-index:2;
  }

  .eyebrow {
    font-size:15px;
    letter-spacing:0.28em;
    color:#C4922A;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:12px;
    text-shadow:0 1px 8px rgba(0,0,0,0.7);
  }
  .name {
    font-size:101px;
    font-weight:200;
    letter-spacing:0.04em;
    color:#EDE6D8;
    line-height:1;
    margin-bottom:12px;
    text-shadow:0 2px 24px rgba(0,0,0,0.85), 0 0 48px rgba(0,0,0,0.4);
  }
  .tagline {
    font-size:20px;
    letter-spacing:0.18em;
    color:rgba(220,210,195,0.75);
    text-transform:uppercase;
    margin-bottom:36px;
    text-shadow:0 1px 8px rgba(0,0,0,0.6);
  }
  .bar-wrap {
    position:absolute;
    bottom:16px; left:72px; right:72px;
    height:10px;
    background:#1a3a58;
    border-radius:9999px;
    z-index:3;
  }
  .bar-fill {
    height:100%; width:0%;
    background: #E8B84B;
    border-radius:9999px;
    -ms-transition: width 0.5s ease;
    transition:    width 0.5s ease;
  }
  .status-row {
    width:100%;
    margin-bottom:8px;
  }
  .pct-text {
    float:right;
    font-size:15px;
    color:rgba(232,184,75,0.9);
    letter-spacing:0.04em;
    font-weight:600;
  }
  .status-text {
    font-size:17px;
    color:rgba(220,210,195,0.65);
    letter-spacing:0.04em;
  }
  #dots {
    font-size:17px;
    color:rgba(196,146,42,0.85);
    letter-spacing:0.01em;
  }
</style>
</head>
<body>

  <img id="bgImg" src="file:///C:/Users/huann/LatitudeMedTech/Athena/ui/splash_bg.jpg" alt=""/>
  <div id="overlay"></div>

  <div id="content">
    <div class="eyebrow">Latitude MedTech</div>
    <div class="name">Athena</div>
    <div class="tagline">Advancing Human Intelligence</div>
    <div class="status-row">
      <span class="pct-text" id="pct">0%</span>
      <span class="status-text" id="status">Starting up</span><span id="dots">.</span>
    </div>
  </div>
  <div class="bar-wrap"><div class="bar-fill" id="bar"></div></div>

<script language="VBScript">
Dim bar, statusEl, dotsEl, pctEl, stepVal, targetVal, timer_id, poll_id, abort_id, waited, readyToClose
Dim BACKEND, FRONTEND, MAX_WAIT
Dim dragging, dragLastX, dragLastY
Dim msgIdx, currentPhase, msgTimer_id, bkMsgs, feMsgs, rdMsgs
Dim dotState, dots_id
BACKEND  = "http://127.0.0.1:8000/"
FRONTEND = "http://localhost:3000"
MAX_WAIT = 60
waited   = 0
targetVal    = 0
readyToClose = False

Sub Window_OnLoad
  ' On Error Resume Next: a resize/image failure must never stop the timers and
  ' drag handlers from registering — those are what close the splash correctly.
  On Error Resume Next

  ' ── Critical section: these MUST register regardless of what follows ──────
  Set bar      = document.getElementById("bar")
  Set statusEl = document.getElementById("status")
  Set dotsEl   = document.getElementById("dots")
  Set pctEl    = document.getElementById("pct")
  stepVal      = 0
  targetVal    = 0
  readyToClose = False
  timer_id = window.setInterval("Tick",        16)
  poll_id  = window.setInterval("PollBackend", 800)
  abort_id = window.setInterval("PollAbort",   300)
  dotState = 0
  dots_id  = window.setInterval("TickDots",   400)

  bkMsgs = Split("Initializing,Loading FastAPI server,Connecting to database,Registering API routes,Loading Memory agent,Initializing coaching orchestrator,Loading Kokoro voice engine,Warming up TTS pipeline", ",")
  feMsgs = Split("Starting Vite dev server,Resolving module dependencies,Compiling React components,Bundling frontend assets", ",")
  rdMsgs = Split("Loading workspace settings,Connecting voice pipeline,Preparing Athena interface,Launching in Chrome", ",")
  currentPhase = "backend"
  msgIdx = 0
  msgTimer_id = window.setInterval("RotateMsg", 2000)
  RotateMsg
  ' Pin splash above Chrome as soon as the HTA window is ready.
  window.setTimeout "MakeTopmost", 400

  ' Click-drag to move the borderless window.
  dragging = False
  Set document.onmousedown = GetRef("Drag_Begin")
  Set document.onmousemove = GetRef("Drag_Move")
  Set document.onmouseup   = GetRef("Drag_End")
  Set document.ondragstart   = GetRef("CancelEvent")
  Set document.onselectstart = GetRef("CancelEvent")

  ' ── Window sizing — best effort ───────────────────────────────────────────
  Dim aw, ah, al, at, pw, ph
  aw = Screen.availWidth : ah = Screen.availHeight
  al = 0 : at = 0
  pw = Int(aw * 0.7) : ph = Int(ah * 0.7)
  If pw < 640  Then pw = 640
  If ph < 360  Then ph = 360
  Err.Clear
  window.resizeTo pw, ph
  window.moveTo al + (aw - pw) \ 2, at + (ah - ph) \ 2

  ' ── Background image cover-fill (source 1400×350) — best effort ──────────
  Err.Clear
  Dim img, sW, sH, scaleW, scaleH, scale, newW, newH
  sW = 1400.0 : sH = 350.0
  scaleW = pw / sW : scaleH = ph / sH
  If scaleW > scaleH Then scale = scaleW Else scale = scaleH
  newW = Int(sW * scale) : newH = Int(sH * scale)
  Set img = document.getElementById("bgImg")
  img.style.width  = newW & "px"
  img.style.height = newH & "px"
  img.style.left   = Int((pw - newW) * 0.28) & "px"
  img.style.top    = Int((ph - newH) / 2) & "px"
  img.style.display = "block"

  ' ── Force bar-wrap pixel width for IE quirks (left/right % can collapse) ──
  Err.Clear
  Dim barWrap
  Set barWrap = document.getElementById("bar").parentNode
  barWrap.style.width = (pw - 144) & "px"
  barWrap.style.left = "72px"
End Sub

Sub CancelEvent
  window.event.returnValue = False
End Sub

Sub Drag_Begin
  If window.event.button = 1 Then
    dragging  = True
    dragLastX = window.event.screenX
    dragLastY = window.event.screenY
    document.body.setCapture
  End If
End Sub

Sub Drag_Move
  If dragging Then
    window.moveBy window.event.screenX - dragLastX, window.event.screenY - dragLastY
    dragLastX = window.event.screenX
    dragLastY = window.event.screenY
  End If
End Sub

Sub Drag_End
  If dragging Then
    dragging = False
    document.releaseCapture
  End If
End Sub

Sub SetStatus(msg, newTarget)
  statusEl.innerText = msg
  If newTarget > targetVal Then targetVal = newTarget
End Sub

Sub TickDots
  dotState = (dotState + 1) Mod 3
  Select Case dotState
    Case 0: dotsEl.innerText = "."
    Case 1: dotsEl.innerText = ".."
    Case 2: dotsEl.innerText = "..."
  End Select
End Sub

Sub RotateMsg
  Select Case currentPhase
    Case "backend"
      If msgIdx <= UBound(bkMsgs) Then
        statusEl.innerText = bkMsgs(msgIdx)
        msgIdx = msgIdx + 1
      End If
    Case "frontend"
      If msgIdx <= UBound(feMsgs) Then
        statusEl.innerText = feMsgs(msgIdx)
        msgIdx = msgIdx + 1
      End If
    Case "chrome"
      If msgIdx <= UBound(rdMsgs) Then
        statusEl.innerText = rdMsgs(msgIdx)
        msgIdx = msgIdx + 1
      End If
  End Select
End Sub

Sub Tick
  If stepVal < targetVal Then
    Dim inc
    If stepVal >= 50 Then
      ' Fast asymptotic tracking — closes 2.5% of remaining gap per frame
      ' so stepVal stays close to targetVal and the bar closes instantly on done.
      inc = (targetVal - stepVal) * 0.025
      If inc < 0.05 Then inc = 0.05
    Else
      inc = 0.04
    End If
    stepVal = stepVal + inc
    If stepVal > targetVal Then stepVal = targetVal
  ElseIf Not readyToClose Then
    ' Keep-alive: stepVal has converged to the animation ceiling while loading is
    ' still in progress. Advance at 0.05/frame (320 ms per percentage point) so
    ' the bar cycles through every whole-number percentage without freezing.
    ' Wrap at 99.5 (the readyToClose trigger) so the bar resets to targetVal and
    ' starts the cycle again -- no ceiling can ever cause a permanent stall.
    stepVal = stepVal + 0.05
    If stepVal >= 99.5 Then stepVal = targetVal
  End If
  bar.style.width = stepVal & "%"
  On Error Resume Next
  pctEl.innerText = Int(stepVal) & "%"
  ' Close once the bar is visually at 100%. Use >= 99.5 rather than 100 to
  ' avoid CInt rounding (99.9 displays as "100%" but fails an exact >= 100 check).
  If readyToClose And stepVal >= 99.5 Then
    window.clearInterval timer_id
    window.setTimeout "CloseSplash", 100
  End If
End Sub

Sub CloseSplash
  ' Write the done-signal BEFORE closing (DI-019-L): start_athena.ps1 polls for this
  ' file before opening Chrome, guaranteeing causal ordering instead of a fixed sleep.
  On Error Resume Next
  Dim fso
  Set fso = CreateObject("Scripting.FileSystemObject")
  fso.CreateTextFile "C:\Users\huann\LatitudeMedTech\Athena\ui\.athena_splash_done", True
  window.close()
End Sub

Sub PollBackend
  waited = waited + 1
  If waited > MAX_WAIT Then
    SetStatus "Connection timed out - please try again", 0
    window.clearInterval poll_id
    window.clearInterval timer_id
    window.setTimeout "window.close()", 3000
    Exit Sub
  End If
  Dim xhr
  Set xhr = CreateObject("MSXML2.ServerXMLHTTP")
  On Error Resume Next
  xhr.open "GET", BACKEND, False
  xhr.setTimeouts 500, 500, 500, 500
  xhr.send
  If Err.Number = 0 And xhr.status = 200 Then
    currentPhase = "frontend"
    msgIdx = 0
    If targetVal < 50 Then targetVal = 50
    window.clearInterval poll_id
    poll_id = window.setInterval("PollFrontend", 800)
  Else
    If targetVal < 15 Then targetVal = 15
  End If
  On Error Resume Next
  Err.Clear
End Sub

Sub PollFrontend
  Dim xhr
  Set xhr = CreateObject("MSXML2.ServerXMLHTTP")
  On Error Resume Next
  xhr.open "GET", FRONTEND, False
  xhr.setTimeouts 500, 500, 500, 500
  xhr.send
  If Err.Number = 0 And xhr.status = 200 Then
    currentPhase = "chrome"
    msgIdx = 0
    If targetVal < 80 Then targetVal = 80
    window.clearInterval poll_id
    poll_id = window.setInterval("PollChromeReady", 500)
  Else
    If targetVal < 65 Then targetVal = 65
  End If
  On Error Resume Next
  Err.Clear
End Sub

Sub PollChromeReady
  Dim fso, adv
  Set fso = CreateObject("Scripting.FileSystemObject")
  If fso.FileExists("C:\Users\huann\LatitudeMedTech\Athena\ui\.athena_ready") Then
    currentPhase = "done"
    window.clearInterval msgTimer_id
    statusEl.innerText = "Welcome back. Athena is ready."
    targetVal = 100
    On Error Resume Next
    window.clearInterval dots_id
    dotsEl.style.display = "none"
    On Error Resume Next
    window.clearInterval poll_id
    readyToClose = True
  ElseIf targetVal < 97 Then
    ' Close 3% of remaining gap per poll (every 500ms). Organic deceleration —
    ' never hits 100% display before .athena_ready fires (cap at 97 keeps
    ' CInt/Int from rounding to 100 prematurely regardless of model load time).
    adv = (100 - targetVal) * 0.03
    If adv < 0.05 Then adv = 0.05
    targetVal = targetVal + adv
    If targetVal > 97 Then targetVal = 97
  End If
End Sub

Sub PollAbort
  ' Existing instance — user chose not to restart. Stop all animation and
  ' close immediately so the splash doesn't linger behind the existing window.
  Dim fso
  Set fso = CreateObject("Scripting.FileSystemObject")
  If fso.FileExists("C:\Users\huann\LatitudeMedTech\Athena\ui\.athena_abort") Then
    window.clearInterval abort_id
    window.clearInterval poll_id
    window.clearInterval timer_id
    window.clearInterval dots_id
    window.close()
  End If
End Sub

Sub MakeTopmost
  ' Call SetWindowPos(HWND_TOPMOST) on this mshta process so the splash
  ' floats above Chrome during the final 95→100% countdown.
  On Error Resume Next
  Dim fso, wsh, f, ts
  Set fso = CreateObject("Scripting.FileSystemObject")
  Set wsh = CreateObject("WScript.Shell")
  f = fso.GetSpecialFolder(2) & "\~ath_top.ps1"
  Set ts = fso.CreateTextFile(f, True)
  ts.WriteLine "Add-Type -TypeDefinition @'"
  ts.WriteLine "using System;using System.Runtime.InteropServices;"
  ts.WriteLine "public class AU{"
  ts.WriteLine "  [DllImport(""user32.dll"")]"
  ts.WriteLine "  public static extern bool SetWindowPos(IntPtr h,IntPtr i,int x,int y,int cx,int cy,uint f);"
  ts.WriteLine "}"
  ts.WriteLine "'@"
  ts.WriteLine "$p=Get-Process mshta 2>$null|Sort-Object StartTime -Descending|Select-Object -First 1"
  ts.WriteLine "if($p -and $p.MainWindowHandle -ne 0){"
  ts.WriteLine "  [AU]::SetWindowPos($p.MainWindowHandle,[IntPtr](-1),0,0,0,0,3)"
  ts.WriteLine "}"
  ts.Close
  wsh.Run "powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File """ & f & """", 0, False
End Sub
</script>
</body>
</html>
