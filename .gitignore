# ============================================================
# OS / editor cruft
# ============================================================
.DS_Store
Thumbs.db

# Runtime database (regenerable, not versioned)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
Athena/memory/
# Runtime flag files
Athena/ui/.athena_ready
Athena/ui/.athena_error
Athena/ui/.athena_chrome.pid
Athena/ui/.athena_session.json

# Isolated Chrome profile — contains cookies/login data, never commit
Athena/ui/.chrome-profile/

# Voice runtime state (regenerable session logs / history)
Athena/voice/.athena_history.json
Athena/voice/sessions.jsonl
Athena/voice/.noise_profile.json
Athena/voice/query_telemetry.jsonl

# Session state (written at launch/exit, not source-controlled)
Athena/ui/.athena_session.json

# Generated deliverables output — not source
Athena/documents/

# Vendored third-party TTS clone (has its own .git — not a submodule)
Athena/voice/miso/

# Voice training artifacts (captured audio samples, candidate model files)
Athena/voice/samples/
Athena/voice/wake_synth/*.pkl

# Stray patch artifacts (leftover output from local diff/patch tooling)
*.mypatch

# Auto-generated RAG learning artifacts (agent feedback loops write these at runtime)
Athena/knowledge_base/learning/
# Tavily web-search cache (ephemeral, not source-controlled)
Athena/knowledge_base/FDA/tavily_*.json
Athena/knowledge_base/General/tavily_*.json

# Google Drive integration — credentials and upload cache (never commit)
Athena/credentials.json
Athena/drive_cache.json
